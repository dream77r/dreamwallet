generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Auth & Users
// ─────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?   @map("avatar_url")
  emailVerified Boolean   @default(false) @map("email_verified")
  role          UserRole  @default(USER) @map("role")
  aiModel       String?   @map("ai_model")
  currency      String    @default("RUB")
  timezone      String    @default("Europe/Moscow")
  locale        String    @default("ru")
  dashboardLayout Json?   @map("dashboard_layout")
  onboardingDone  Boolean   @default(false) @map("onboarding_done")
  userProfile     String?   @map("user_profile")  // beginner | experienced | business
  reports         Report[]
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Better Auth relations
  sessions Session[]
  accounts OAuthAccount[]

  // App relations
  personalWallet   Wallet?           @relation("PersonalWallet")
  projects         Project[]         @relation("ProjectOwner")
  projectMembers   ProjectMember[]
  transactionSeens TransactionSeen[]
  createdTransactions Transaction[] @relation("TransactionCreator")
  categories       Category[]
  subscriptions    Subscription[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  importTemplates  ImportTemplate[]
  autoRules        AutoCategoryRule[]
  goals            Goal[]
  debts            Debt[]
  tags             Tag[]
  pushSubscriptions PushSubscription[]
  telegramConn     TelegramConnection?

  // New feature relations
  familyMembers_   FamilyMember[]
  splitGroups      SplitGroup[]      @relation("SplitGroupCreator")
  splitParticipants SplitParticipant[]
  challenges       Challenge[]
  achievements     Achievement[]
  streak           UserStreak?
  smartRuleSuggestions SmartRuleSuggestion[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model OAuthAccount {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  provider          String
  providerAccountId String  @map("provider_account_id")
  password          String?
  accessToken       String? @map("access_token")
  refreshToken      String? @map("refresh_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verifications")
}

// ─────────────────────────────────────────────
// Wallets & Accounts
// ─────────────────────────────────────────────

model Wallet {
  id        String     @id @default(cuid())
  name      String
  type      WalletType @default(PERSONAL)
  currency  String     @default("RUB")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  // Personal wallet owner (null for project wallets)
  userId String? @unique @map("user_id")
  user   User?   @relation("PersonalWallet", fields: [userId], references: [id], onDelete: Cascade)

  // Project wallet (null for personal wallets)
  projectId String?  @unique @map("project_id")
  project   Project? @relation("ProjectWallet", fields: [projectId], references: [id], onDelete: Cascade)

  accounts Account[]
  budgets  Budget[]
  familyWallet FamilyWallet?

  @@map("wallets")
}

enum WalletType {
  PERSONAL
  PROJECT
  FAMILY
}

model Account {
  id             String      @id @default(cuid())
  walletId       String      @map("wallet_id")
  name           String
  type           AccountType
  currency       String      @default("RUB")
  balance        Decimal     @default(0) @db.Decimal(15, 2)
  initialBalance Decimal     @default(0) @map("initial_balance") @db.Decimal(15, 2)
  icon           String?
  color          String?
  isArchived     Boolean     @default(false) @map("is_archived")
  sortOrder      Int         @default(0) @map("sort_order")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  // Crypto fields
  cryptoAddress   String?   @map("crypto_address")
  cryptoNetwork   String?   @map("crypto_network")
  cryptoSymbol    String?   @map("crypto_symbol")
  lastSyncAt      DateTime? @map("last_sync_at")

  wallet          Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  bankConnection  BankConnection?
  transactions    Transaction[]   @relation("TransactionAccount")
  transfersFrom   Transaction[]   @relation("TransferFrom")
  transfersTo     Transaction[]   @relation("TransferTo")
  recurringRules  RecurringRule[] @relation("AccountRecurring")
  cashbackRules   CashbackRule[]
  cashbackEntries CashbackEntry[]
  investmentPositions InvestmentPosition[]

  @@map("accounts")
}

enum AccountType {
  BANK_ACCOUNT
  CASH
  CRYPTO
  INVESTMENT
  CREDIT_CARD
  SAVINGS
  CUSTOM
}

// ─────────────────────────────────────────────
// Transactions
// ─────────────────────────────────────────────

model Transaction {
  id            String          @id @default(cuid())
  accountId     String          @map("account_id")
  type          TransactionType
  amount        Decimal         @db.Decimal(15, 2)
  currency      String          @default("RUB")
  date          DateTime        @db.Date
  description   String?
  counterparty  String?
  reference     String?
  isRecurring   Boolean         @default(false) @map("is_recurring")
  source           TransactionSource @default(MANUAL)
  originalAmount   Decimal?        @map("original_amount") @db.Decimal(15, 2)
  originalCurrency String?         @map("original_currency")
  exchangeRate     Decimal?        @map("exchange_rate") @db.Decimal(18, 8)
  metadata         Json?
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  account       Account         @relation("TransactionAccount", fields: [accountId], references: [id], onDelete: Cascade)
  categoryId    String?         @map("category_id")
  category      Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdById   String?         @map("created_by_id")
  createdBy     User?           @relation("TransactionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  tags          TagOnTransaction[]
  attachments   Attachment[]
  cashbackEntries CashbackEntry[]

  // Transfer fields
  transferFromAccountId String?  @map("transfer_from_account_id")
  transferToAccountId   String?  @map("transfer_to_account_id")
  transferFromAccount   Account? @relation("TransferFrom", fields: [transferFromAccountId], references: [id])
  transferToAccount     Account? @relation("TransferTo", fields: [transferToAccountId], references: [id])

  // Recurring transaction template
  recurringRuleId String?        @map("recurring_rule_id")
  recurringRule   RecurringRule? @relation(fields: [recurringRuleId], references: [id])

  @@index([accountId, date])
  @@index([categoryId])
  @@index([date])
  @@index([source])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionSource {
  MANUAL
  CSV_IMPORT
  BANK_SYNC
  API
  RECURRING
  TELEGRAM_SMS
  TELEGRAM_SCREENSHOT
}

// ─────────────────────────────────────────────
// Categories & Tags
// ─────────────────────────────────────────────

model Category {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  name      String
  type      CategoryType
  icon      String?
  color     String?
  parentId  String?      @map("parent_id")
  isDefault Boolean      @default(false) @map("is_default")
  sortOrder Int          @default(0) @map("sort_order")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Category?         @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]        @relation("CategoryTree")
  transactions Transaction[]
  budgets      Budget[]
  autoRules    AutoCategoryRule[]
  recurringRules RecurringRule[] @relation("CategoryRecurring")
  cashbackRules  CashbackRule[]
  smartRuleSuggestions SmartRuleSuggestion[]

  @@unique([userId, name, parentId])
  @@map("categories")
}

enum CategoryType {
  INCOME
  EXPENSE
}

model Tag {
  id        String             @id @default(cuid())
  userId    String             @map("user_id")
  name      String
  color     String             @default("#6366f1")
  createdAt DateTime           @default(now()) @map("created_at")

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions TagOnTransaction[]

  @@unique([userId, name])
  @@map("tags")
}

model TagOnTransaction {
  transactionId String @map("transaction_id")
  tagId         String @map("tag_id")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
  @@map("tags_on_transactions")
}

// ─────────────────────────────────────────────
// Budgets
// ─────────────────────────────────────────────

model Budget {
  id             String       @id @default(cuid())
  walletId       String       @map("wallet_id")
  categoryId     String       @map("category_id")
  amount         Decimal      @db.Decimal(15, 2)
  period         BudgetPeriod
  alertThreshold Int          @default(80) @map("alert_threshold")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  wallet   Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([walletId, categoryId, period])
  @@map("budgets")
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

// ─────────────────────────────────────────────
// Projects
// ─────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  ownerId     String        @map("owner_id")
  name        String
  description String?
  icon        String?
  color       String?
  currency    String        @default("RUB")
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  owner   User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  wallet  Wallet?         @relation("ProjectWallet")
  members ProjectMember[]
  reports Report[]
  incomeRules     IncomeRule[]
  payouts         Payout[]
  transactionSeens TransactionSeen[]

  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String      @map("project_id")
  userId    String      @map("user_id")
  role      MemberRole  @default(VIEWER)
  invitedAt DateTime    @default(now()) @map("invited_at")
  joinedAt  DateTime?   @map("joined_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeRule IncomeRule?
  payouts    Payout[]

  @@unique([projectId, userId])
  @@map("project_members")
}

enum MemberRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

// ─────────────────────────────────────────────
// Bank Connections
// ─────────────────────────────────────────────

model BankConnection {
  id             String               @id @default(cuid())
  accountId      String               @unique @map("account_id")
  provider       BankProvider
  providerName   String?              @map("provider_name")
  externalId     String?              @map("external_id")
  credentials    String?              // AES-256-GCM encrypted JSON
  lastSyncAt     DateTime?            @map("last_sync_at")
  syncSchedule   String?              @map("sync_schedule") // cron expression
  status         BankConnectionStatus @default(ACTIVE)
  errorMessage   String?              @map("error_message")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  account    Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  syncLogs   BankSyncLog[]

  @@map("bank_connections")
}

enum BankProvider {
  TOCHKA
  SBER
  TBANK
  ALFA
  SALT_EDGE
  CUSTOM
}

enum BankConnectionStatus {
  ACTIVE
  EXPIRED
  ERROR
  DISCONNECTED
}

model BankSyncLog {
  id               String   @id @default(cuid())
  bankConnectionId String   @map("bank_connection_id")
  status           String   // success, error, partial
  transactionsAdded Int     @default(0) @map("transactions_added")
  transactionsSkipped Int   @default(0) @map("transactions_skipped")
  errorMessage     String?  @map("error_message")
  startedAt        DateTime @map("started_at")
  completedAt      DateTime? @map("completed_at")

  bankConnection BankConnection @relation(fields: [bankConnectionId], references: [id], onDelete: Cascade)

  @@map("bank_sync_logs")
}

// ─────────────────────────────────────────────
// Auto-categorization Rules
// ─────────────────────────────────────────────

model AutoCategoryRule {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  categoryId String   @map("category_id")
  field      String   @default("description") // description, counterparty
  pattern    String   // regex or keyword
  isRegex    Boolean  @default(false) @map("is_regex")
  priority   Int      @default(0)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("auto_category_rules")
}

// ─────────────────────────────────────────────
// Recurring Rules
// ─────────────────────────────────────────────

model RecurringRule {
  id            String   @id @default(cuid())
  name          String
  amount        Decimal  @db.Decimal(15, 2)
  type          TransactionType
  schedule      String   // cron expression
  nextRunAt     DateTime @map("next_run_at")
  isActive      Boolean  @default(true) @map("is_active")
  reminderDays  Int      @default(3) @map("reminder_days")
  accountId     String?  @map("account_id")
  categoryId    String?  @map("category_id")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  account      Account?  @relation("AccountRecurring", fields: [accountId], references: [id], onDelete: SetNull)
  category     Category? @relation("CategoryRecurring", fields: [categoryId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@map("recurring_rules")
}

// ─────────────────────────────────────────────
// Import
// ─────────────────────────────────────────────

model ImportTemplate {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  provider    String?  // "tinkoff", "sber", "alfa", "custom"
  columnMap   Json     @map("column_map") // { date: "A", amount: "B", description: "C" }
  dateFormat  String?  @map("date_format")
  delimiter   String?  @default(",")
  skipRows    Int      @default(0) @map("skip_rows")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("import_templates")
}

// ─────────────────────────────────────────────
// Reports
// ─────────────────────────────────────────────

model Report {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  projectId String?  @map("project_id")
  name      String
  type      String   // pnl, cashflow, category_breakdown, custom
  filters   Json?    // saved filter state
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("reports")
}

// ─────────────────────────────────────────────
// Attachments
// ─────────────────────────────────────────────

model Attachment {
  id            String   @id @default(cuid())
  transactionId String   @map("transaction_id")
  filename      String
  mimeType      String   @map("mime_type")
  size          Int
  url           String
  createdAt     DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

// ─────────────────────────────────────────────
// Subscriptions (Billing)
// ─────────────────────────────────────────────

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @map("user_id")
  plan               SubscriptionPlan   @default(FREE)
  status             SubscriptionStatus @default(ACTIVE)
  provider           PaymentProvider?
  externalId         String?            @map("external_id")
  stripeCustomerId   String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?          @unique @map("stripe_subscription_id")
  currentPeriodStart DateTime?          @map("current_period_start")
  currentPeriodEnd   DateTime?          @map("current_period_end")
  cancelAtPeriodEnd  Boolean            @default(false) @map("cancel_at_period_end")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
  CUSTOM
}

// Configurable plan limits — editable via admin panel
model PlanConfig {
  id                       String           @id @default(cuid())
  plan                     SubscriptionPlan @unique
  displayName              String           @map("display_name")
  priceMonthly             Int              @default(0) @map("price_monthly")
  priceYearly              Int              @default(0) @map("price_yearly")
  maxAccounts              Int              @default(3) @map("max_accounts")           // -1 = unlimited
  maxProjects              Int              @default(1) @map("max_projects")           // -1 = unlimited
  maxBankConnections       Int              @default(0) @map("max_bank_connections")   // -1 = unlimited
  maxProjectMembers        Int              @default(0) @map("max_project_members")    // -1 = unlimited
  transactionHistoryMonths Int              @default(6) @map("transaction_history_months") // -1 = unlimited
  hasAiCategorization      Boolean          @default(false) @map("has_ai_categorization")
  hasCustomReports         Boolean          @default(false) @map("has_custom_reports")
  hasExport                Boolean          @default(false) @map("has_export")
  hasApiAccess             Boolean          @default(false) @map("has_api_access")
  isVisible                Boolean          @default(true) @map("is_visible")  // false = only in admin
  sortOrder                Int              @default(0) @map("sort_order")
  createdAt                DateTime         @default(now()) @map("created_at")
  updatedAt                DateTime         @updatedAt @map("updated_at")

  @@map("plan_configs")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum PaymentProvider {
  STRIPE
  YUKASSA
}

// ─────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String?
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

enum NotificationType {
  BUDGET_WARNING
  BUDGET_EXCEEDED
  LARGE_TRANSACTION
  BANK_SYNC_ERROR
  BANK_SYNC_COMPLETE
  SYSTEM
  PROACTIVE_ADVICE
}

// ─────────────────────────────────────────────
// Audit Log
// ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String   // create, update, delete
  entity    String   // transaction, account, project, etc.
  entityId  String   @map("entity_id")
  changes   Json?    // { field: { old: "x", new: "y" } }
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// Goals (Financial Goals)
// ─────────────────────────────────────────────

model Goal {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  name          String
  targetAmount  Decimal   @db.Decimal(15, 2) @map("target_amount")
  currentAmount Decimal   @default(0) @db.Decimal(15, 2) @map("current_amount")
  deadline      DateTime?
  icon          String?
  color         String?
  isCompleted   Boolean   @default(false) @map("is_completed")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("goals")
}

// ─────────────────────────────────────────────
// Debts & Loans
// ─────────────────────────────────────────────

enum DebtType {
  LENT
  BORROWED
}

enum DebtStatus {
  ACTIVE
  PARTIALLY_REPAID
  REPAID
  CANCELLED
}

model Debt {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  type         DebtType
  status       DebtStatus @default(ACTIVE)
  counterparty String
  amount       Decimal    @db.Decimal(15, 2)
  currency     String     @default("RUB")
  paidAmount   Decimal    @default(0) @db.Decimal(15, 2) @map("paid_amount")
  description  String?
  dueDate      DateTime?  @map("due_date")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("debts")
}

// ─────────────────────────────────────────────
// Telegram Bot Connections
// ─────────────────────────────────────────────

model TelegramConnection {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  chatId       String   @unique @map("chat_id")
  username     String?
  firstName    String?  @map("first_name")
  linkedAt     DateTime @default(now()) @map("linked_at")
  isActive            Boolean   @default(true)  @map("is_active")
  notifyTransactions  Boolean   @default(true)  @map("notify_transactions")
  notifyBudgets       Boolean   @default(true)  @map("notify_budgets")
  notifyGoals         Boolean   @default(false) @map("notify_goals")
  notifyAdvice        Boolean   @default(true)  @map("notify_advice")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_connections")
}

// ─────────────────────────────────────────────
// Web Push Subscriptions
// ─────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String   @map("p256dh")   // DH public key
  auth      String                     // Auth secret
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// ─────────────────────────────────────────────
// App Settings (key-value, managed by superadmin)
// ─────────────────────────────────────────────

model AppSetting {
  key       String   @id
  value     String   // JSON-encoded value
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") // userId

  @@map("app_settings")
}

// ─────────────────────────────────────────────
// Income Distribution & Payouts
// ─────────────────────────────────────────────

enum IncomeRuleType {
  PERCENTAGE
  FIXED
}

model IncomeRule {
  id        String         @id @default(cuid())
  projectId String         @map("project_id")
  memberId  String         @map("member_id")
  type      IncomeRuleType
  value     Decimal        @db.Decimal(15, 2)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member  ProjectMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([projectId, memberId])
  @@unique([memberId])
  @@map("income_rules")
}

model Payout {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  memberId  String   @map("member_id")
  amount    Decimal  @db.Decimal(15, 2)
  period    String   // "2026-03"
  note      String?
  paidAt    DateTime @default(now()) @map("paid_at")
  createdAt DateTime @default(now()) @map("created_at")

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member  ProjectMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([projectId, period])
  @@map("payouts")
}

model TransactionSeen {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  userId     String   @map("user_id")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("transaction_seens")
}

// ─────────────────────────────────────────────
// Exchange Rates (Multi-Currency)
// ─────────────────────────────────────────────

model ExchangeRate {
  id       String   @id @default(cuid())
  fromCur  String   @map("from_cur")
  toCur    String   @map("to_cur")
  rate     Decimal  @db.Decimal(18, 8)
  date     DateTime @db.Date
  source   String   @default("CBR") // CBR, ECB, manual
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([fromCur, toCur, date, source])
  @@index([fromCur, toCur, date])
  @@map("exchange_rates")
}

// ─────────────────────────────────────────────
// Family Budget
// ─────────────────────────────────────────────

model FamilyWallet {
  id        String          @id @default(cuid())
  name      String
  currency  String          @default("RUB")
  walletId  String          @unique @map("wallet_id")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  wallet    Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  members   FamilyMember[]
  invites   FamilyInvite[]

  @@map("family_wallets")
}

enum FamilyRole {
  OWNER
  ADMIN
  MEMBER
}

model FamilyMember {
  id              String       @id @default(cuid())
  familyWalletId  String       @map("family_wallet_id")
  userId          String       @map("user_id")
  role            FamilyRole   @default(MEMBER)
  spendingLimit   Decimal?     @db.Decimal(15, 2) @map("spending_limit")
  joinedAt        DateTime     @default(now()) @map("joined_at")

  familyWallet    FamilyWallet @relation(fields: [familyWalletId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyWalletId, userId])
  @@map("family_members")
}

model FamilyInvite {
  id              String       @id @default(cuid())
  familyWalletId  String       @map("family_wallet_id")
  token           String       @unique
  expiresAt       DateTime     @map("expires_at")
  usedAt          DateTime?    @map("used_at")
  createdAt       DateTime     @default(now()) @map("created_at")

  familyWallet    FamilyWallet @relation(fields: [familyWalletId], references: [id], onDelete: Cascade)

  @@map("family_invites")
}

// ─────────────────────────────────────────────
// Split Expenses
// ─────────────────────────────────────────────

model SplitGroup {
  id          String             @id @default(cuid())
  name        String
  currency    String             @default("RUB")
  createdById String             @map("created_by_id")
  shareToken  String?            @unique @map("share_token")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  createdBy    User              @relation("SplitGroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants SplitParticipant[]
  expenses     SplitExpense[]

  @@map("split_groups")
}

model SplitParticipant {
  id           String        @id @default(cuid())
  groupId      String        @map("group_id")
  userId       String?       @map("user_id")
  externalName String?       @map("external_name")
  externalEmail String?      @map("external_email")

  group        SplitGroup    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  shares       SplitShare[]
  paidExpenses SplitExpense[] @relation("SplitExpensePayer")
  payments     SplitPayment[] @relation("SplitPaymentFrom")
  receivedPayments SplitPayment[] @relation("SplitPaymentTo")

  @@map("split_participants")
}

model SplitExpense {
  id          String        @id @default(cuid())
  groupId     String        @map("group_id")
  paidById    String        @map("paid_by_id")
  description String
  amount      Decimal       @db.Decimal(15, 2)
  splitType   String        @default("equal") @map("split_type") // equal, custom, percent
  date        DateTime      @default(now()) @db.Date
  createdAt   DateTime      @default(now()) @map("created_at")

  group       SplitGroup    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy      SplitParticipant @relation("SplitExpensePayer", fields: [paidById], references: [id], onDelete: Cascade)
  shares      SplitShare[]

  @@map("split_expenses")
}

model SplitShare {
  id            String           @id @default(cuid())
  expenseId     String           @map("expense_id")
  participantId String           @map("participant_id")
  amount        Decimal          @db.Decimal(15, 2)

  expense       SplitExpense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  participant   SplitParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([expenseId, participantId])
  @@map("split_shares")
}

model SplitPayment {
  id           String           @id @default(cuid())
  groupId      String           @map("group_id")
  fromId       String           @map("from_id")
  toId         String           @map("to_id")
  amount       Decimal          @db.Decimal(15, 2)
  createdAt    DateTime         @default(now()) @map("created_at")

  from         SplitParticipant @relation("SplitPaymentFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to           SplitParticipant @relation("SplitPaymentTo", fields: [toId], references: [id], onDelete: Cascade)

  @@map("split_payments")
}

// ─────────────────────────────────────────────
// Gamification
// ─────────────────────────────────────────────

enum ChallengeStatus {
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

model Challenge {
  id         String          @id @default(cuid())
  userId     String          @map("user_id")
  type       String          // no_spend, budget_limit, savings_target, streak_keep
  title      String
  status     ChallengeStatus @default(ACTIVE)
  progress   Int             @default(0)
  target     Int
  config     Json?           // category, amount, etc.
  startsAt   DateTime        @map("starts_at")
  endsAt     DateTime        @map("ends_at")
  createdAt  DateTime        @default(now()) @map("created_at")

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("challenges")
}

model Achievement {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String   // first_tx, tx_100, budget_master, streak_7, streak_30, goal_reached
  title     String
  icon      String
  earnedAt  DateTime @default(now()) @map("earned_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("achievements")
}

model UserStreak {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  currentStreak  Int      @default(0) @map("current_streak")
  longestStreak  Int      @default(0) @map("longest_streak")
  lastActiveDate DateTime? @map("last_active_date") @db.Date
  totalPoints    Int      @default(0) @map("total_points")
  level          Int      @default(1)
  updatedAt      DateTime @updatedAt @map("updated_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streaks")
}

// ─────────────────────────────────────────────
// Cashback Tracker
// ─────────────────────────────────────────────

model CashbackRule {
  id          String   @id @default(cuid())
  accountId   String   @map("account_id")
  categoryId  String?  @map("category_id")
  rate        Decimal  @db.Decimal(5, 2) // percentage
  maxMonthly  Decimal? @db.Decimal(15, 2) @map("max_monthly")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("cashback_rules")
}

model CashbackEntry {
  id            String   @id @default(cuid())
  accountId     String   @map("account_id")
  transactionId String?  @map("transaction_id")
  amount        Decimal  @db.Decimal(15, 2)
  isReceived    Boolean  @default(false) @map("is_received")
  createdAt     DateTime @default(now()) @map("created_at")

  account       Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@map("cashback_entries")
}

// ─────────────────────────────────────────────
// Smart Rule Suggestions
// ─────────────────────────────────────────────

enum SmartRuleStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model SmartRuleSuggestion {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  pattern     String
  field       String          @default("description")
  categoryId  String          @map("category_id")
  confidence  Decimal         @db.Decimal(5, 2)
  status      SmartRuleStatus @default(PENDING)
  matchCount  Int             @default(0) @map("match_count")
  createdAt   DateTime        @default(now()) @map("created_at")

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("smart_rule_suggestions")
}

// ─────────────────────────────────────────────
// Investment Tracker
// ─────────────────────────────────────────────

model InvestmentPosition {
  id        String    @id @default(cuid())
  accountId String    @map("account_id")
  ticker    String
  name      String?
  quantity  Decimal   @db.Decimal(15, 6)
  avgPrice  Decimal   @db.Decimal(15, 2) @map("avg_price")
  currency  String    @default("RUB")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  dividends DividendPayment[]

  @@unique([accountId, ticker])
  @@map("investment_positions")
}

model DividendPayment {
  id         String   @id @default(cuid())
  positionId String   @map("position_id")
  amount     Decimal  @db.Decimal(15, 2)
  date       DateTime @db.Date
  createdAt  DateTime @default(now()) @map("created_at")

  position   InvestmentPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@map("dividend_payments")
}

model StockPrice {
  id     String   @id @default(cuid())
  ticker String
  price  Decimal  @db.Decimal(15, 2)
  date   DateTime @db.Date

  @@unique([ticker, date])
  @@index([ticker, date])
  @@map("stock_prices")
}
